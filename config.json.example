# Copy this file to config.json and fill in your actual values.
# config.json is gitignored — never commit it with real secrets.
#
# "replacements" lets you fix common ASR mistakes (e.g. "big said" → "big sad").
# Add key/value pairs where the key is what ASR produces and the value is
# what you want to see instead. Replacements are applied case-insensitively.

{
  "twitch": {
    "app_id": "YOUR_TWITCH_APP_ID",
    "app_secret": "YOUR_TWITCH_APP_SECRET",
    "target_channel": "YOUR_CHANNEL_NAME",
    "refresh_token": "YOUR_REFRESH_TOKEN"
  },
  "hallucinations": ["The.", "."],
  "erase_keyword": "not what i said",
  "replacements": {},
  "audio_input_device": null,
  "audio_output_device": null
}
